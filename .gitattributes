# Normalize line endings to LF in the repo; check out as-is on all platforms
* text=auto eol=lf

# Binary assets — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.ttf binary
*.woff binary
*.woff2 binary
*.eot binary
*.otf binary
*.wav binary
*.mp3 binary
*.ogg binary
*.node binary
